# Godot 4+ specific ignores
.godot/
/android/

# Export output
builds/
exports/

# Import cache
*.import

# Temp files
*.tmp

# Generated at build time
version.txt

# Logs
logs/

# Editor/tool config
.claude/*
!.claude/agents/
.vscode/
.mcp.json
.cursorrules
.windsurfrules
.github/copilot-instructions.md

# Personal lefthook overrides
lefthook-local.yml
scripts/dev/

# Editor-only dev addons (per-dev preference, no runtime/CI impact)
addons/signal_lens/

# Mood boards (third-party copyrighted material, local only). Fully excluded:
# the text docs reference external works in ways we keep internal.
designs/art/mood-boards/

# Private design docs: internal-only, synced to Notion rather than the public repo.
designs/private/

# Essay process residue: section drafts only.
# Final essays, persistent research notes, critical reviews, and meta planning docs stay tracked.
designs/research/drafts/

# Swarm scratchpad: ephemeral per work unit, scrubbed on completion.
# The README and per-agent definitions stay tracked; working state does not.
ai/swarm/agents/
ai/swarm/tasks/
ai/swarm/inbox/
ai/swarm/_bootstrap.md

# OS junk
.DS_Store
Thumbs.db

# live-update smoke PR touch, safe to revert
