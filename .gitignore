# Godot 4+ specific ignores
.godot/
/android/

# Export output
builds/
exports/

# Import cache
*.import

# Temp files
*.tmp

# Generated at build time
version.txt

# Logs
logs/

# Editor/tool config
.claude/*
!.claude/agents/
!.claude/skills/
!.claude/settings.json
!.claude/hooks/
.vscode/
.mcp.json
.cursorrules
coverage.json
.windsurfrules
.github/copilot-instructions.md

# Personal lefthook overrides
lefthook-local.yml

# Editor-only dev addons (per-dev preference, no runtime/CI impact)
addons/signal_lens/

# Mood boards (third-party copyrighted material, local only). Fully excluded:
# the text docs reference external works in ways we keep internal.
designs/art/mood-boards/


# Private design docs: internal-only, synced to Notion rather than the public repo.
designs/private/

# Essay process residue: section drafts only.
# Final essays, persistent research notes, critical reviews, and meta planning docs stay tracked.
designs/research/drafts/

# Swarm scratchpad: ephemeral per work unit, scrubbed on completion.
# The README and per-agent definitions stay tracked; working state does not.
ai/swarm/agents/
ai/swarm/tasks/
ai/swarm/inbox/
ai/swarm/_bootstrap.md

# Scratchpads: ephemeral working state; per-session notes, research dumps,
# the injection-guard hook log. Not committed.
ai/scratchpads/

# Art-app autosaves and temp files (commit the source masters, not the crash recovery)
*-autosave.kra
*.kra~
*.psd~
*.xcf~
*.psb.tmp
*.psd.tmp
*.ai.tmp
*.svg.tmp
~*.ai
~*.psd
.~lock.*
*.aseprite-data
*.ase~
*.aseprite~
*.blend1
*.blend2
*.blend@
# Animation apps (Spine, DragonBones, After Effects, Moho)
*.spine-backup
*.dbbak
*.aep~
*.aep.lock
*.moho~
# Frame-by-frame apps (OpenToonz, TVPaint, Pencil2D) autosaves and backups
*.tnz~
*.tvpp~
*.pclx~
*.pcl~
*_bak.pclx
backup/*.tnz
/sandbox/

# OS junk
.DS_Store
Thumbs.db

# live-update smoke PR touch, safe to revert

.godotiq/

# OpenCode local config (personal memory pointer, machine-specific)
.opencode/
