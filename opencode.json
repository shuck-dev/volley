{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "dispatch",
  "share": "disabled",
  "tools": {
    "task": false
  },
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "webfetch": "deny",
    "bash": {
      // Josh owns the merge, close, and release lifecycle.
      "gh pr merge*": "deny",
      "gh pr close*": "deny",
      "gh release delete*": "deny",
      "gh release create*": "deny",
      // Rewrites history; ask first.
      "git rebase*": "ask",
      "*git rebase*": "ask",
      // Banned history-rewrite commands.
      "git filter-branch*": "deny",
      "*git filter-branch*": "deny",
      // Rewrites the remote; need consent.
      "git push *--force*": "ask",
      "*git push *--force*": "ask",
      // Merge instead to avoid silent conflicts.
      "git pull *--rebase*": "deny",
      // Force-delete branches; use worktree cleanup instead.
      "git branch *-D *": "deny",
      // Destructive recursive delete.
      "rm -rf *": "deny",
      // File deletion; confirm each.
      "rm *": "ask",
      // Use MCP tools instead.
      "python*": "deny",
      // Blocked, never poll.
      "*sleep *": "deny",
      // Use the Linear MCP tool instead.
      "*linear.app/graphql*issueCreate*": "ask",
      "*linear.app/graphql*issueUpdate*": "ask"
    },
    "linear_save_issue": "ask",
    "linear_save_project": "ask",
    "linear_save_comment": "ask",
    "linear_save_document": "ask",
    "linear_save_milestone": "ask",
    "linear_save_initiative": "ask",
    "linear_save_status_update": "ask",
    "linear_delete_status_update": "ask",
    "linear_create_issue_label": "ask",
    "linear_delete_comment": "ask",
    "linear_create_attachment": "ask",
    "linear_create_attachment_from_upload": "ask",
    "linear_delete_attachment": "ask",
    "external_directory": {
      "*": "ask",
      "/home/josh/gamedev/volley-ai/**": "allow",
      "/tmp/opencode-swarm-reports/**": "allow",
      "/tmp/**": "allow"
    }
  },
  "mcp": {
    "godotiq": {
      "type": "local",
      "command": [
        "uvx",
        "godotiq"
      ],
      "enabled": true,
      "environment": {
        "GODOTIQ_PROJECT_ROOT": "/home/josh/gamedev/volley",
        "GODOTIQ_ADDON_HOST": "172.30.160.1"
      }
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "headers": {
        "Authorization": "Bearer {env:LINEAR_API_KEY}"
      }
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    }
  }
}
